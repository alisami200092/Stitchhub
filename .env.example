# -----------------------------------------------------------------------------
# StitchHub B2B Command Center - Environment Configurations Example
# -----------------------------------------------------------------------------

# Direct connection string to PostgreSQL (used by Drizzle ORM for migrations/updates)
DATABASE_URL="postgresql://<user>:<password>@<host>:<port>/<dbname>"

# Supabase API URL (Project Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Supabase Anonymous/Publishable Key (Project Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-supabase-anon-key>"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<your-supabase-publishable-key>"

# Brevo SMTP/Transactional Email API Key (used for sending transactional alerts)
BREVO_API_KEY="xkeysib-..."

# Polar.sh Payment Processing (sandbox environment for development)
# Create an organization access token at https://sandbox.polar.sh/settings
POLAR_ACCESS_TOKEN="polar_at_..."
POLAR_WEBHOOK_SECRET="whsec_..."

# Product ID for the deposit payment product created in Polar.sh sandbox dashboard
POLAR_PRODUCT_ID="<product-id-from-polar-dashboard>"

# Public site URL (used for webhook callbacks and redirects)
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Gemini API Fallback configuration (used as temporary backup for agent generation)
GEMINI_API_KEY="AIzaSy..."
GEMINI_MODEL="gemini-2.5-flash"
